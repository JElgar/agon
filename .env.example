JWT_SECRET=39c17075523912ad7f9163380990854047f0490f357038f08de6f4644114dc0a
AGON_SERVICE_URL=http://localhost:7000

# DynamoDB single table + AWS creds (the service and worker read these).
AGON_TABLE_NAME=agon
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Meilisearch (discovery/search endpoints). Matches docker-compose.
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=masterKeyForLocalDevOnly

# Observability (OTLP export of logs, traces, metrics). See docs/observability.md.
# Leave OTEL_EXPORTER_OTLP_ENDPOINT UNSET for local dev — the apps then log JSON
# to stdout only and skip all export (no collector needed). Point it at an OTLP
# collector (Grafana Alloy in the cluster) to enable export.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=agon-service   # set per-binary; the code passes a default
