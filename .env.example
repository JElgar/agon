# ── JWT auth (asymmetric) ──────────────────────────────────────────────────
# Tokens are verified against public keys — never a shared secret. The service
# trusts two sources (either alone is fine; set what you need):
#   SUPABASE_JWKS_URL  — Supabase's JWKS endpoint for real user tokens.
#   AGON_STATIC_JWKS   — a JSON JWK Set of always-trusted public keys. Used to
#                        trust the test/local signing key below.
# SUPABASE_JWKS_URL=https://<project>.supabase.co/auth/v1/.well-known/jwks.json
# AGON_STATIC_JWKS={"keys":[{"kty":"EC","crv":"P-256","alg":"ES256","use":"sig","kid":"agon-test","x":"...","y":"..."}]}
#
# The private key (PKCS#8 PEM) the integration tests and `generate-token` CLI
# sign with. Its public half must be the JWK in AGON_STATIC_JWKS, and the kid
# must match AGON_TEST_JWT_KID (default `agon-test`). Test/local only.
# AGON_TEST_JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# AGON_TEST_JWT_KID=agon-test

AGON_SERVICE_URL=http://localhost:7000

# DynamoDB single table + AWS creds (the service and worker read these).
AGON_TABLE_NAME=agon
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Meilisearch (discovery/search endpoints). Matches docker-compose.
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=masterKeyForLocalDevOnly

# ── Object storage: image uploads (profile / team / match) ─────────────────
# Private S3 bucket the service issues presigned PUTs against, and the base CDN
# URL images are served from. In the cluster these are injected from Pulumi
# (see agon_infra); set them locally only if exercising the upload flow.
AGON_ASSETS_BUCKET=agon-assets
# CloudFront (or other CDN) base URL, no trailing slash. The service builds
# public serving URLs and signs match-header URLs against this; the worker
# stores the canonical URL on an asset when it uploads.
# AGON_ASSETS_CDN_URL=https://dxxxx.cloudfront.net
# SQS queue the worker long-polls for S3 object-created (upload) events.
# AGON_ASSET_EVENTS_QUEUE_URL=
# CloudFront signed-URL key pair for match-header serving. Only set to enable
# signing; when unset the service serves match headers unsigned (dev).
# AGON_CLOUDFRONT_KEY_PAIR_ID=
# AGON_CLOUDFRONT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Observability (OTLP export of logs, traces, metrics). See docs/observability.md.
# Leave OTEL_EXPORTER_OTLP_ENDPOINT UNSET for local dev — the apps then log JSON
# to stdout only and skip all export (no collector needed). Point it at an OTLP
# collector (Grafana Alloy in the cluster) to enable export.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=agon-service   # set per-binary; the code passes a default
